# Images published from main
FRONTEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-runtime-frontend:main
BACKEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-runtime-backend:main

# Compose / runtime
APP_ENV_FILE=.env.prod
# Local-only app bootstrap for first-run smoke. Do not use this with NGINX_BIND_HOST=0.0.0.0.
NGINX_DEFAULT_CONF=./nginx/prod-bootstrap.conf
NGINX_BIND_HOST=127.0.0.1
CERTBOT_WWW_DIR=./certbot/www
LETSENCRYPT_DIR=./certbot/conf
PROXY_KNOWN_NETWORK=172.16.0.0/12
CODEX_HOME_DIR=./.codex-runtime

# Keep main/prod localhost-only by default. Set NGINX_BIND_HOST=0.0.0.0 only when you intentionally publish the service.
# For external Let's Encrypt HTTP-01 issuance, temporarily set:
# NGINX_DEFAULT_CONF=./nginx/prod-acme-only.conf
# This exposes only /.well-known/acme-challenge/* and closes app routes such as /blog.

# Database
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DATA_DIR=./.docker-data/prod/postgres
MEDIA_DATA_DIR=./.docker-data/prod/media
DATA_PROTECTION_DIR=./.docker-data/prod/data-protection
# Optional explicit override. Normally derived from POSTGRES_* by docker-compose.prod.yml
# ConnectionStrings__Postgres=Host=db;Port=5432;Database=portfolio;Username=portfolio;Password=change-me

# Azure backup / restore
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BACKUP_CONTAINER=woong-blog-prod-backups
AZURE_BACKUP_PREFIX=woong-blog/prod
AZURE_BACKUP_LOG_FILE=./.docker-data/prod/azure-backup.log
AZURE_BACKUP_COMPOSE_FILE=docker-compose.prod.yml
AZURE_BACKUP_DB_SERVICE=db

# Auth / production
Auth__Enabled=true
Auth__Authority=https://accounts.google.com
Auth__ClientId=replace-me
Auth__ClientSecret=replace-me
Auth__PublicOrigin=https://example.com
Auth__CallbackPath=/api/auth/callback
Auth__SignedOutRedirectPath=/
Auth__CookieName=portfolio_auth
Auth__AdminEmails__0=admin@example.com
Auth__DataProtectionKeysPath=/app/data-protection
Auth__MediaRoot=/app/media
Auth__SecureCookies=true
Auth__RequireHttpsMetadata=true
Auth__SlidingExpirationMinutes=20
Auth__AbsoluteExpirationHours=8
Auth__EnableTestLoginEndpoint=false

# Proxy / forwarded headers
# docker-compose.prod.yml injects Proxy__KnownNetworks__0 from PROXY_KNOWN_NETWORK
Proxy__ForwardLimit=2
Proxy__RequireHeaderSymmetry=false
# Optional explicit entries when you need tighter reverse-proxy control
# Proxy__KnownProxies__0=127.0.0.1
# Proxy__KnownProxies__1=::1
# Proxy__KnownNetworks__0=172.16.0.0/12

# AI / Codex
AI_PROVIDER=codex
CODEX_COMMAND=codex
CODEX_ARGUMENTS=exec
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
CODEX_ALLOWED_MODELS=gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
CODEX_TIMEOUT_MS=180000
CODEX_WORKDIR=
AI_BATCH_CONCURRENCY=4
AI_BATCH_COMPLETED_RETENTION_DAYS=3

# Optional OpenAI / Azure OpenAI values when AI_PROVIDER is not codex
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional Cloudflare R2 values for media/video features
CloudflareR2__AccountId=
CloudflareR2__AccessKeyId=
CloudflareR2__SecretAccessKey=
CloudflareR2__BucketName=
CloudflareR2__Endpoint=
CloudflareR2__BrowserEndpoint=
CloudflareR2__PublicUrl=
CloudflareR2__ForceEnabledInDevelopment=false

# Security
Security__UseHttpsRedirection=true
Security__UseHsts=true
Security__HstsMaxAgeDays=365
Security__HstsIncludeSubDomains=true
Security__HstsPreload=false
Security__ReferrerPolicy=strict-origin-when-cross-origin
Security__PermissionsPolicy=camera=(), microphone=(), geolocation=()
Security__ContentSecurityPolicy=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self' https://accounts.google.com; img-src 'self' data: https: blob:; object-src 'none'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https://accounts.google.com https://www.googleapis.com;
Security__AuthRateLimitPermitLimit=20
Security__AuthRateLimitWindowSeconds=60
Security__AntiforgeryHeaderName=X-CSRF-TOKEN
Security__AntiforgeryCookieName=portfolio_xsrf

# Logging / hosting
AllowedHosts=*
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning
