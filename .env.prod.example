# Images published from main
FRONTEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-frontend:main
BACKEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-backend:main

# Compose / runtime
APP_ENV_FILE=.env.prod
NGINX_DEFAULT_CONF=./nginx/prod-bootstrap.conf
CERTBOT_WWW_DIR=./certbot/www
LETSENCRYPT_DIR=./certbot/conf
PROXY_KNOWN_NETWORK=172.16.0.0/12

# Database
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me

# Auth / production
Auth__Enabled=true
Auth__Authority=https://accounts.google.com
Auth__ClientId=replace-me
Auth__ClientSecret=replace-me
Auth__CallbackPath=/api/auth/callback
Auth__SignedOutRedirectPath=/
Auth__CookieName=portfolio_auth
Auth__AdminEmails__0=admin@example.com
Auth__DataProtectionKeysPath=/app/data-protection
Auth__MediaRoot=/app/media
Auth__SecureCookies=true
Auth__RequireHttpsMetadata=true
Auth__SlidingExpirationMinutes=20
Auth__AbsoluteExpirationHours=8

# Security
Security__UseHttpsRedirection=true
Security__UseHsts=true
