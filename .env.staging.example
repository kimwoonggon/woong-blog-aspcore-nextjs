# Images published from dev
FRONTEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-frontend:dev
BACKEND_IMAGE=ghcr.io/your-owner/woong-blog-aspcore-nextjs-backend:dev

# Compose / runtime
APP_ENV_FILE=.env.staging
NEXT_PUBLIC_SITE_URL=https://staging.example.com
NGINX_DEFAULT_CONF=./nginx/prod-bootstrap.conf
CERTBOT_WWW_DIR=./certbot/www
LETSENCRYPT_DIR=./certbot/conf
PROXY_KNOWN_NETWORK=172.16.0.0/12
CODEX_HOME_DIR=./.codex-runtime

# Database
POSTGRES_DB=portfolio_staging
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DATA_DIR=./.docker-data/staging/postgres

# Auth / staging
Auth__Enabled=true
Auth__Authority=https://accounts.google.com
Auth__ClientId=replace-me
Auth__ClientSecret=replace-me
Auth__PublicOrigin=https://staging.example.com
Auth__CallbackPath=/api/auth/callback
Auth__SignedOutRedirectPath=/
Auth__CookieName=portfolio_auth_staging
Auth__AdminEmails__0=admin@example.com
Auth__DataProtectionKeysPath=/app/data-protection
Auth__MediaRoot=/app/media
Auth__SecureCookies=true
Auth__RequireHttpsMetadata=true
Auth__SlidingExpirationMinutes=300
Auth__AbsoluteExpirationHours=8

# AI / Codex
AI_PROVIDER=codex
CODEX_COMMAND=codex
CODEX_ARGUMENTS=exec
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
CODEX_ALLOWED_MODELS=gpt-5.4,gpt-5.3-codex,gpt-5.3-codex-spark
CODEX_ALLOWED_REASONING_EFFORTS=low,medium,high,xhigh
CODEX_TIMEOUT_MS=180000

# Security
Security__UseHttpsRedirection=true
Security__UseHsts=true
